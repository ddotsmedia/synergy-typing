# =============================================================================
# Synergy Typing — environment template
# Copy to .env.local (never commit real values). Secrets belong in Vercel/host.
# =============================================================================

# --- app ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NODE_ENV=development

# --- database (Neon / PostgreSQL) ---
DATABASE_URL=postgresql://user:pass@localhost:5432/synergy?schema=public
DIRECT_URL=postgresql://user:pass@localhost:5432/synergy?schema=public

# --- auth (Auth.js v5) ---
AUTH_SECRET=replace-with-32+-char-random
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_UAE_PASS_CLIENT_ID=
AUTH_UAE_PASS_CLIENT_SECRET=

# --- email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM="Synergy Typing <noreply@synergytyping.com>"

# --- storage (Cloudflare R2 S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=synergy-docs
R2_PUBLIC_URL=

# --- payments (Stripe + UAE adapters) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
TELR_STORE_ID=
TELR_AUTH_KEY=
NI_API_KEY=

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=
AI_DAILY_USD_CAP=10
AI_KILL_SWITCH=false

# --- cache / rate limit (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- background jobs (Inngest) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- observability ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- whatsapp (stub for Business API) ---
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
NEXT_PUBLIC_WHATSAPP_NUMBER=971506601090

# --- business constants ---
NEXT_PUBLIC_CONTACT_PHONE=+97125542220
NEXT_PUBLIC_CONTACT_EMAIL=info@synergytyping.com
NEXT_PUBLIC_VAT_TRN=TO_VERIFY
