# Place at /opt/proxy/.env on the VPS — used by infra/proxy/docker-compose.yml.

# Email used by Let's Encrypt for certificate-expiry warnings.
LETSENCRYPT_EMAIL=info@example.com

# Optional: a separate hostname for the Traefik /ping endpoint, useful for
# uptime monitoring services. Leave at the default to disable the route.
PROXY_PING_HOST=traefik.invalid
